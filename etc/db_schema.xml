<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="magewatch_log_offset" resource="default" engine="innodb" comment="MageWatch Agent Log File Offsets">
        <column xsi:type="varchar" name="file_path" nullable="false" length="255" comment="Absolute log file path"/>
        <column xsi:type="bigint" name="byte_offset" unsigned="true" nullable="false" default="0" comment="Last read byte offset"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Last Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="file_path"/>
        </constraint>
    </table>
</schema>
