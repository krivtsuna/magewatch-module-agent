<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="magewatch" translate="label" sortOrder="500">
            <label>MageWatch</label>
        </tab>
        <section id="magewatch" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Agent</label>
            <tab>magewatch</tab>
            <resource>MageWatch_Agent::config</resource>
            <group id="agent" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <comment>Enable the MageWatch monitoring agent cron job.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="endpoint_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>API Endpoint URL</label>
                    <comment>Ingest URL for heartbeats. Production default: https://ingest.magewatch.io/api/v1/ingest (DNS-only subdomain; bypasses Cloudflare bot challenges). Change only for self-hosted MageWatch (see install docs for Docker).</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="site_token" translate="label comment" type="obscure" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Site Token</label>
                    <comment>Bearer token issued by MageWatch for this installation. Stored encrypted.</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="stuck_cron_threshold_minutes" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Stuck Cron Threshold (minutes)</label>
                    <comment>A cron job still "running" longer than this is reported as stuck. Default: 30.</comment>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="rum_enabled" translate="label comment" type="select" sortOrder="45" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Frontend monitoring (RUM)</label>
                    <comment>Injects a tiny script on storefront pages to report JS errors, funnel activity counters, and Web Vitals. No cookies, no PII, no session IDs. Requires a paid MageWatch plan. Disable here to stop injection without uninstalling the agent.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="test_ping" translate="label comment" type="button" sortOrder="50" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Test Connection</label>
                    <comment>Builds a live payload and sends it to the configured endpoint immediately.</comment>
                    <frontend_model>MageWatch\Agent\Block\Adminhtml\System\Config\TestPing</frontend_model>
                </field>
            </group>
            <group id="collectors" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Collectors</label>
                <field id="indexer" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Indexer Collector</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="cron" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Cron Collector</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="queue" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Queue Collector</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="order_stats" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Order Stats Collector</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="log" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Log Collector</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="system" translate="label" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>System Collector</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="security" translate="label comment" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Security Collector</label>
                    <comment>Scans pub/ for unexpected PHP, suspicious patterns, and new admin users.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="composer" translate="label comment" type="select" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Composer Collector</label>
                    <comment>Sends composer.lock packages and enabled modules for MageVulnDB extension checks.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="storefront_probe" translate="label comment" type="select" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Storefront Probe Collector</label>
                    <comment>Checks homepage and checkout from the Magento server (origin) to avoid false WAF alerts.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="report" translate="label comment" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Error Report Collector</label>
                    <comment>Reads the newest files from var/report (Magento error report dumps).</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="infrastructure" translate="label comment" type="select" sortOrder="110" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Infrastructure Collector</label>
                    <comment>Probes Redis cache backend and OpenSearch/Elasticsearch cluster reachability.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="database" translate="label comment" type="select" sortOrder="120" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Database Collector</label>
                    <comment>MySQL health via SHOW GLOBAL STATUS and long-running InnoDB transactions (read-only).</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
