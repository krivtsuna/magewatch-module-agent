<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="magewatch-rum-script" type="host">https://magewatch.io</value>
                <value id="magewatch-rum-script-ingest" type="host">https://ingest.magewatch.io</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="magewatch-rum-ingest" type="host">https://magewatch.io</value>
                <value id="magewatch-rum-ingest-direct" type="host">https://ingest.magewatch.io</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
