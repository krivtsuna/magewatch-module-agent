{
    "name": "magewatch/module-agent",
    "description": "Read-only monitoring agent for Magento 2 that collects health metrics and pushes them to the MageWatch SaaS API.",
    "type": "magento2-module",
    "license": "OSL-3.0",
    "keywords": [
        "magento2",
        "magento",
        "monitoring",
        "cron",
        "indexer",
        "magewatch",
        "saas"
    ],
    "authors": [
        {
            "name": "MageWatch",
            "homepage": "https://magewatch.io"
        }
    ],
    "homepage": "https://magewatch.io/docs/install",
    "support": {
        "issues": "https://github.com/krivtsuna/magewatch-module-agent/issues",
        "source": "https://github.com/krivtsuna/magewatch-module-agent"
    },
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0||~8.4.0",
        "magento/framework": "*",
        "magento/module-backend": "*",
        "magento/module-config": "*",
        "magento/module-cron": "*",
        "magento/module-indexer": "*",
        "magento/module-sales": "*",
        "magento/module-store": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "MageWatch\\Agent\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MageWatch\\Agent\\Test\\": "Test/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
